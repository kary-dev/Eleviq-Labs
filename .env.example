# --- Database (Postgres, e.g. Neon) ---
# Use the DIRECT (non-pooled) connection string so `prisma db push` works on deploy.
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth.js core ---
# Generate a strong value with: npx auth secret
AUTH_SECRET="generate-with-npx-auth-secret"
# On Vercel this is auto-detected (trustHost is on); only set for local dev.
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# --- Discord OAuth ---
# 1. Go to https://discord.com/developers/applications -> New Application
# 2. OAuth2 tab -> copy Client ID and Client Secret below
# 3. OAuth2 -> Redirects -> add BOTH:
#      http://localhost:3000/api/auth/callback/discord   (local)
#      https://YOUR-APP.vercel.app/api/auth/callback/discord   (production)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# --- Admins ---
# Comma-separated emails that auto-become ADMIN on sign-in (use your Discord email).
# Note: eleviqlabs@gmail.com is always an admin (baked into the code).
ADMIN_EMAILS=""

# --- Instagram data (for verification + clip auto-fetch) ---
# Without any key, a deterministic MOCK provider runs so the flow is testable.
# Provider preference: APIFY_TOKEN > RAPIDAPI_KEY > mock.
#
# Option A — Apify (recommended free tier ~$5/mo credits). Create a token at
# https://console.apify.com/account/integrations and paste it here. Actor ids
# are overridable if you swap actors.
APIFY_TOKEN=""
APIFY_PROFILE_ACTOR="apify~instagram-profile-scraper"
APIFY_POST_ACTOR="apify~instagram-scraper"
#
# Option B — RapidAPI scraper. Default host targets the "instagram-scraper-api2"
# shape; override if you use a different API.
RAPIDAPI_KEY=""
RAPIDAPI_INSTAGRAM_HOST="instagram-scraper-api2.p.rapidapi.com"
# In production WITHOUT a key, Instagram verification is disabled (won't fake-pass).
# Set to "true" to allow the mock provider in production for demos only.
ALLOW_MOCK_INSTAGRAM=""
